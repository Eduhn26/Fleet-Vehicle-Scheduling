# Server configuration
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb+srv://<usuario>:<senha>@cluster.mongodb.net/fleet_vehicle_scheduling

# Authentication
JWT_SECRET=sua_chave_secreta_aqui

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3000

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Python analytics service
# Use http://localhost:8000 when Node runs directly on Windows.
# Docker Compose overrides this with http://host.docker.internal:8000.
ANALYTICS_SERVICE_URL=http://localhost:8000
ANALYTICS_SERVICE_TIMEOUT_MS=5000
